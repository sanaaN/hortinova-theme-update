          },
          {
            "type": "product_list",
            "id": "product_list",
            "label": "t:sections.local-extra-words.sections.main-product.blocks.related.settings.products",
            "limit": 3
          }
        ]
      },
      {
        "type": "icons",
        "name": "t:sections.local-extra-words.sections.main-product.blocks.icons.name",
        "limit": 1,
        "settings": [
          {
            "type": "text",
