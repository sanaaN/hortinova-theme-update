s":{"desktop_height":"40vh","mobile_height":"40vh","alignment":"horizontal-center align-content--vertical-bottom","text_size":"large","title_size":"h2","button_size":"large","button_style":"outline","is_fullwidth":true}},"cb8efefa-1297-47f9-8b0c-75398a18ba13":{"type":"rich-text","blocks":{"template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-title-1":{"type":"title","settings":{"title":"Our Quality","title_size":"h3"}},"template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-text-1":{"type":"text","settings":{"text":"<p>All our seeds are tested by a CFIA-accredited seed laboratory prior to release to ensure lots comply with applicable regulations. We take the utmost care to provide only high grade seeds with the highest  germination possible.<br\/><br\/>The test results and dates of each seed lot are communicated openly on our website and of course on the seed packets.<\/p><p>All our seeds are NON-GMO and chemical free.<\/p>","text_size":"large"}},"template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-button-1":{"type":"button","settings":{"button_label":"About us","link":"https:\/\/shop.hortinova.ca\/pages\/about-us","button_size":"large","button_style":"outline"}}},"block_order":["template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-title-1","template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-text-1","template--16476823421178__cb8efefa-1297-47f9-8b0c-75398a18ba13-button-1"],"disabled":true,"settings":{"height":"small","image":"shopify:\/\/shop_images\/seed-germination-tips_14ed3fb2-bcf6-40c1-8ca9-76e07f4443ad.jpg","image_position":"left","image_crop":false,"text_alignment":"horizontal-left","is_fullwidth":true,"remove_margin":false,"color_background_main":"rgba(0,0,0,0)","color_text_main":"#19212c","color_borders_main":"rgba(0,0,0,0)","color_hide_borders":true}},"e6855973-ce86-4731-8139-ebe857087a38":{"type":"rich-text","blocks":{"template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-title-1":{"type":"title","settings":{"title":"Our Packaging","title_size":"h3"}},"template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-text-1":{"type":"text","settings":{"text":"<ul><li>High-end material that stands out in the market.<\/li><\/ul><p><\/p><ul><li>Versatile packaging and branding for local hobby and professional markets as well as for export.<\/li><\/ul><p><\/p><ul><li>Packets made of aluminum barrier film and heat-sealed to protect the seeds from relative humidity, water and ultraviolet rays.<\/li><\/ul><p><\/p><ul><li>Resealable bags with zipper to allow users to store seeds safely for later sowing.<\/li><\/ul><p><\/p><ul><li>Seeds are placed inside a translucent glassine bag used as a liner to prevent accidental seed spillage and aid in handling.<\/li><\/ul>","text_size":"large"}},"template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-button-1":{"type":"button","settings":{"button_label":"Learn more","link":"https:\/\/shop.hortinova.ca\/pages\/how-to-read-our-package","button_size":"large","button_style":"outline"}}},"block_order":["template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-title-1","template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-text-1","template--16476823421178__e6855973-ce86-4731-8139-ebe857087a38-button-1"],"disabled":true,"settings":{"height":"small","image":"shopify:\/\/shop_images\/PALOMA2.png","image_position":"right","image_crop":false,"text_alignment":"horizontal-left","is_fullwidth":true,"remove_margin":true,"color_background_main":"rgba(0,0,0,0)","color_text_main":"#19212c","color_borders_main":"rgba(0,0,0,0)","color_hide_borders":true}},"165407625224b5d2af":{"type":"rich-text","blocks":{"1654076252f525bcb1-1":{"type":"text","settings":{"text":"<h4><strong>Reseller Offer<\/strong><\/h4>","text_size":"regular"}},"1654076252f525bcb1-0":{"type":"title","settings":{"title":"Ask about our wholesale program","title_size":"h3"}},"4055a9b7-fa9d-4a7a-b5e0-d052561d6f9c":{"type":"text","settings":{"text":"<p>Hortinova is an innovative company in the seed sector with a fresh look at market trends. <\/p><p>We are committed to respecting our partners' requirements and building lasting relationships of trust.<br\/><br\/>For all inquiries related to products and distribution opportunities, please do not hesitate to contact us. We would love to partner with you and become one of your reliable suppliers.<\/p>","text_size":"large"}},"1654076252f525bcb1-2":{"type":"button","settings":{"button_label":"Contact Us","link":"https:\/\/shop.hortinova.ca\/pages\/contact","button_size":"large","button_style":"outline"}}},"block_order":["1654076252f525bcb1-1","1654076252f525bcb1-0","4055a9b7-fa9d-4a7a-b5e0-d052561d6f9c","1654076252f525bcb1-2"],"disabled":true,"settings":{"height":"small","image":"shopify:\/\/shop_images\/04.Hortinova_Display_Double_2.png","image_position":"right","image_crop":false,"text_alignment":"horizontal-left","is_fullwidth":true,"remove_margin":true,"color_background_main":"rgba(0,0,0,0)","color_text_main":"#19212c","color_borders_main":"#e1e1e1","color_hide_borders":true}},"496cdfb9-a6e6-46a9-b455-691ca3a994c6":{"type":"rich-text","blocks":{"template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-title-1":{"type":"title","settings":{"title":"Our Display","title_size":"h3"}},"template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-text-1":{"type":"text","settings":{"text":"<ul><li>If you're looking to combine an effective sales tool with environmentally friendly materials, look no further, as we have exactly what you need.<\/li><\/ul><p><\/p><ul><li>Made 100% from cardboard by a Quebec-based company, this floor display stands out for its lightness compared to metal or wooden displays, making it incredibly convenient to transport.<\/li><\/ul><p><\/p><ul><li>Featuring a capacity of 25 compartments that can hold up to 750 packets, it strikes the perfect balance between functional diversity and captivating aesthetics. Its modular design, both understated and impactful, has been meticulously crafted to grab the consumer's attention. Highly adaptable to different store settings, it transforms into an indispensable asset in the retail space.<\/li><\/ul><p><\/p><ul><li>Once in your possession, you can customize it by assembling your own assortment, thus offering an exceptional variety of species and varieties to your gardening enthusiasts. Rest assured that both amateurs and connoisseurs will be delighted!<\/li><\/ul>","text_size":"large"}},"template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-button-1":{"type":"button","settings":{"button_label":"Learn more","link":"https:\/\/shop.hortinova.ca\/products\/floor-display","button_size":"large","button_style":"outline"}}},"block_order":["template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-title-1","template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-text-1","template--16476823421178__496cdfb9-a6e6-46a9-b455-691ca3a994c6-button-1"],"disabled":true,"settings":{"height":"small","image":"shopify:\/\/shop_images\/02.Hortinova_Display_Double_Side_to_Side.png","image_position":"left","image_crop":false,"text_alignment":"horizontal-left","is_fullwidth":true,"remove_margin":true,"color_background_main":"rgba(0,0,0,0)","color_text_main":"#19212c","color_borders_main":"rgba(0,0,0,0)","color_hide_borders":true}},"1654161920efe5f084":{"type":"text-columns-icons","blocks":{"1654161920f21316cf-0":{"type":"image","settings":{"icon":"passion","title":"Passion","caption":"Our passion for seeds and quality produce guides our vision forward.","link":"","color_background_main":"rgba(0,0,0,0)","color_icons_main":"rgba(0,0,0,0)"}},"1654161920f21316cf-1":{"type":"image","settings":{"icon":"quality","title":"Quality","caption":"High quality seed is the critical first link in the vegetable value chain.","link":"","color_background_main":"rgba(0,0,0,0)","color_icons_main":"rgba(0,0,0,0)"}},"1654161920f21316cf-2":{"type":"image","settings":{"icon":"non-gmo","title":"Non-GMO",