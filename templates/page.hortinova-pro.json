    "72c219b6-4cb2-4258-a2b6-9761451da30c": {
      "type": "rich-text",
      "blocks": {
        "template--16476823519482__72c219b6-4cb2-4258-a2b6-9761451da30c-1667876996f1b842d3-1": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "<h2>Greenhouse Production<\/h2><p><strong>Leveraging our global network and partnerships, we take pride in offering innovative seed varieties catering to the growing environment in the medium and high-tech segments.<\/strong><\/p><p><strong>Our portfolio features high-performance varieties with adapted plant structures and advanced traits, developed to consistently yield high-quality fruits.<\/strong><\/p><p><strong>Selected for enhanced flavor profiles and reliable, marketable yields, our seeds ensure you meet your commitments across the entire fresh produce value chain.<\/strong><\/p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "template--16476823519482__72c219b6-4cb2-4258-a2b6-9761451da30c-1667876996f1b842d3-1"
