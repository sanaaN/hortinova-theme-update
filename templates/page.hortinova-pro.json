    "615b533d-5a29-4718-9fae-7715926d6532": {
      "type": "rich-text",
      "blocks": {
        "template--16476823519482__615b533d-5a29-4718-9fae-7715926d6532-1667877156b3bd3db3-1": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "<p>We believe, as the saying goes, that to plant a seed is to believe in tomorrow. <\/p><p>We trust that you will find in us your reliable partner in seed and that, together, we can farm for the future.​<\/p>",
            "text_size": "large"
          }
        }
      },
